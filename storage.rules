rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper to check if user is the designated admin
    function isAdmin() {
      return request.auth != null && (request.auth.uid == 'bO4hxi9UxndcwtAit5hiy5FyVnD3' || request.auth.token.admin == true);
    }

    match /products/{allPaths=**} {
      // Products are publicly readable
      allow read: if true;
      // Only admins can upload product images
      allow write: if isAdmin();
    }

    // Default rule: Allow users to manage their own folder if needed later
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
